# Glyph Hold runtime configuration.
# Copy to .env for local Docker use. Never commit real .env files.

GLYPHHOLD_DB_PATH=/data/glyphhold.sqlite
GLYPHHOLD_HOST=0.0.0.0
GLYPHHOLD_PORT=5995

# Required for secret storage/reveal. If omitted, non-secret features still work.
# Generate once with: openssl rand -hex 32
# Back this value up. Changing or losing it makes existing stored secrets unreadable.
GLYPHHOLD_ENCRYPTION_KEY=

GLYPHHOLD_LOG_LEVEL=INFO
GLYPHHOLD_LOG_FORMAT=pretty
GLYPHHOLD_EVENT_RETENTION_DAYS=90
GLYPHHOLD_MAX_EVENT_ROWS=100000

# Generous safety limits. Oversized API requests return an actionable error and are never truncated.
GLYPHHOLD_MAX_REQUEST_BYTES=2097152
GLYPHHOLD_MAX_MEMORY_BODY_CHARS=1048576
GLYPHHOLD_MAX_SUMMARY_CHARS=8192
GLYPHHOLD_MAX_SECRET_VALUE_CHARS=1048576

# Only failed dashboard logins and invalid API authentication attempts are rate limited.
GLYPHHOLD_DASHBOARD_LOGIN_ATTEMPTS=5
GLYPHHOLD_DASHBOARD_LOGIN_WINDOW_SECONDS=900
GLYPHHOLD_INVALID_API_KEY_ATTEMPTS=30
GLYPHHOLD_INVALID_API_KEY_WINDOW_SECONDS=60

# Set to true when serving through HTTPS so browser cookies are marked secure.
GLYPHHOLD_COOKIE_SECURE=false
