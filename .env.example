# Tomewarden runtime configuration.
# Copy to .env for local Docker use. Never commit real .env files.

TOMEWARDEN_DB_PATH=/data/tomewarden.sqlite
TOMEWARDEN_HOST=0.0.0.0
TOMEWARDEN_PORT=8787

# Required for secret storage/reveal. If omitted, non-secret features still work.
# Generate a strong value before storing real secrets.
TOMEWARDEN_ENCRYPTION_KEY=

TOMEWARDEN_LOG_LEVEL=INFO
TOMEWARDEN_LOG_FORMAT=pretty
TOMEWARDEN_EVENT_RETENTION_DAYS=90
TOMEWARDEN_MAX_EVENT_ROWS=100000

# Set to true when serving through HTTPS so browser cookies are marked secure.
TOMEWARDEN_COOKIE_SECURE=false

